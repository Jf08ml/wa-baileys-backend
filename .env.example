# Puerto donde escucha Express (detrás de Caddy).
PORT=3001

# Seguridad
API_KEY=apiwhatsappzybi
# Coma-separados si usas varios frontends, o * para permitir todos (recomendado whitelists)
FRONTEND_ORIGIN=https://tu-dominio.com

# Logging
NODE_ENV=production
LOG_LEVEL=info

# Persistencia de sesiones Baileys en disco del VPS
AUTH_ROOT=/opt/wa/auth

# WA Agent — AgenditApp (opcional; omitir para deshabilitar el forwarding)
AGENDITAPP_BACKEND_URL=https://tu-backend.com
WA_AGENT_SECRET=shared_secret_del_backend
